{
  "metadata": [
    {
      "src": [
        {
          "files": [ "Apps/**/*.csproj" ],
          "src": "."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "index.md", "toc.yml" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "Fullness Stationery データ管理サービス",
      "_appTitle": "Fullness Stationery API リファレンス",
      "_enableSearch": true,
      "_lang": "ja"
    }
  }
}